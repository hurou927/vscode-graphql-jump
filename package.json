{
  "name": "graphql-jump",
  "repository": {
    "type": "git",
    "url": "https://github.com/hurou927/vscode-graphql-jump"
  },
  "version": "2.0.0",
  "description": "Jump to GraphQL type definitions from TypeScript/JavaScript files",
  "author": "",
  "type": "commonjs",
  "main": "./out/client.js",
  "bin": {
    "graphql-jump-lsp": "./bin/graphql-jump-lsp.js"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/search.test.js",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "fmt": "oxfmt src",
    "fmt:check": "oxfmt --check src",
    "bump:patch": "./scripts/bump-version.sh patch",
    "bump:minor": "./scripts/bump-version.sh minor",
    "bump:major": "./scripts/bump-version.sh major"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^16.18.126",
    "@types/vscode": "^1.99.3",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^4.9.5"
  },
  "engines": {
    "vscode": "^1.99.3"
  },
  "displayName": "GraphQL Jump",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "contributes": {}
}
